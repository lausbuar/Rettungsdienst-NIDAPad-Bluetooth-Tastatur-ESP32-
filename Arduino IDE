// Scroll-Erkennung: touchstart Position merken
// wenn beim touchend zu weit bewegt -> kein Klick
let _tx=0,_ty=0,_scrolled=false;
document.addEventListener('touchstart',function(e){
  _tx=e.touches[0].clientX;_ty=e.touches[0].clientY;_scrolled=false;
},{passive:true});
document.addEventListener('touchmove',function(e){
  if(Math.abs(e.touches[0].clientX-_tx)>8||Math.abs(e.touches[0].clientY-_ty)>8)_scrolled=true;
},{passive:true});

function selTouch(i,e){if(_scrolled)return;e.preventDefault();sel(i);}
function editTouch(i,e){if(_scrolled)return;e.preventDefault();editTmpl(i);}
function delTouch(i,e){if(_scrolled)return;e.preventDefault();delTmpl(i);}

