// ── API Handler für Vorlagen ──────────────────────────────────────────────────

// GET /api/templates -> gibt alle Vorlagen als JSON
void handleGetTemplates() {
  String data = loadTemplatesFromNVS();
  if (data.isEmpty()) {
    data = getDefaultTemplates();
  }
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.send(200, "application/json; charset=utf-8", data);
}

// POST /api/templates -> speichert alle Vorlagen (Body = JSON Array)
void handleSaveTemplates() {
  if (!server.hasArg("plain")) {
    server.send(400, "application/json", "{\"ok\":false,\"err\":\"kein body\"}");
    return;
  }
  String json = server.arg("plain");
  // Einfache Validierung: muss mit [ anfangen
  if (!json.startsWith("[")) {
    server.send(400, "application/json", "{\"ok\":false,\"err\":\"ungueltig\"}");
    return;
  }
  saveTemplatesToNVS(json);
  Serial.println("[RD] Vorlagen gespeichert: " + String(json.length()) + " Bytes");
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.send(200, "application/json", "{\"ok\":true}");
}

// POST /api/reset -> setzt Vorlagen auf Standard zurück
void handleResetTemplates() {
  prefs.begin("rd_tmpl", false);
  prefs.remove("templates");
  prefs.end();
  server.send(200, "application/json", "{\"ok\":true}");
}

// ── Setup ─────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("[RD] Starte...");

  // LED initialisieren
  led.begin();
  led.setBrightness(80);
  led.setPixelColor(0, led.Color(40, 0, 0));
  led.show();

  // USB HID
  USB.productName("RD Tastatur");
  USB.manufacturerName("Rettungsdienst");
  Keyboard.begin();
  USB.begin();
  Serial.println("[RD] USB HID gestartet");

  delay(1000);

  // WLAN Hotspot
  WiFi.mode(WIFI_AP);
  bool ok = WiFi.softAP(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("[RD] Hotspot: ");
  Serial.println(ok ? "OK" : "FEHLER");
  Serial.print("[RD] IP: ");
  Serial.println(WiFi.softAPIP());

  // Webserver
  // Hauptseite
  server.on("/",                           HTTP_GET,  handleRoot);
  server.on("/send",                       HTTP_POST, handleSend);
  server.on("/connect",                    HTTP_POST, handleConnect);
  server.on("/disconnect",                 HTTP_POST, handleDisconnect);
  // Vorlagen API
  server.on("/api/templates",              HTTP_GET,  handleGetTemplates);
  server.on("/api/templates",              HTTP_POST, handleSaveTemplates);
  server.on("/api/reset",                  HTTP_POST, handleResetTemplates);
  // ── Apple iOS Captive Portal Check URLs ──────────────────────
  // iOS 7+: prueft /hotspot-detect.html bei captive.apple.com
  server.on("/hotspot-detect.html",        HTTP_GET,  handleAppleHotspot);
  // iOS neuere Versionen
  server.on("/library/test/success.html",  HTTP_GET,  handleAppleHotspot);
  server.on("/bag",                        HTTP_GET,  handleAppleHotspot);
  // ── Android Captive Portal ───────────────────────────────────
  server.on("/generate_204",               HTTP_GET,  handleGenericPortal);
  server.on("/gen_204",                    HTTP_GET,  handleGenericPortal);
  // ── Windows NCA ──────────────────────────────────────────────
  server.on("/ncsi.txt",                   HTTP_GET,  handleGenericPortal);
  server.on("/connecttest.txt",            HTTP_GET,  handleGenericPortal);
  server.on("/fwlink",                     HTTP_GET,  handleGenericPortal);
  server.on("/redirect",                   HTTP_GET,  handleGenericPortal);
  // Alles andere -> Weiterleitung
  server.onNotFound([]() {
    if (isCaptivePortalRequest()) {
      handleCaptivePortal();
    } else {
      server.sendHeader("Location", "http://192.168.4.1", true);
      server.send(302, "text/plain", "");
    }
  });
  server.begin();

  // DNS Server starten - leitet ALLE Domains auf ESP32 um
  dnsServer.start(DNS_PORT, "*", WiFi.softAPIP());

  Serial.println("[RD] Bereit!");
  Serial.println("[RD] WLAN: RD-Tastatur | PW: rettung123");
  Serial.println("[RD] URL: 192.168.4.1");
}

// ── Loop ──────────────────────────────────────────────────────────────────────
void loop() {
  dnsServer.processNextRequest();
  server.handleClient();
  updateLED();
  delay(1);
}
