// ── Captive Portal Handler ────────────────────────────────────────────────────
void handleCaptivePortal() {
  server.sendHeader("Location", "http://192.168.4.1", true);
  server.send(302, "text/plain", "");
}

// iOS Success Seite - gibt bewusst KEINEN Success zurueck
// -> iOS denkt kein Internet -> oeffnet Captive Portal Browser
void handleAppleHotspot() {
  // Wichtig: Content muss sich von echtem Apple Response unterscheiden
  // Echter Apple Response: "<HTML><HEAD><TITLE>Success</TITLE></HEAD><BODY>Success</BODY></HTML>"
  // Wir senden eine Weiterleitung statt Success -> iOS oeffnet Browser
  server.sendHeader("Location", "http://192.168.4.1", true);
  server.send(302, "text/html", "");
}

// Windows / Android Captive Portal
void handleGenericPortal() {
  server.sendHeader("Location", "http://192.168.4.1", true);
  server.send(302, "text/plain", "");
}

bool isCaptivePortalRequest() {
  String host = server.hostHeader();
  return (host != "192.168.4.1" && host != "");
}

// ── HTTP Handler ──────────────────────────────────────────────────────────────
void handleRoot() {
  server.send_P(200, "text/html; charset=utf-8", HTML);
}

void handleSend() {
  clientConnected = true;
  if (!server.hasArg("text")) {
    server.send(400, "application/json", "{\"ok\":false}");
    return;
  }
  String text = server.arg("text");
  server.send(200, "application/json", "{\"ok\":true}");
  delay(100);
  sendText(text);
}

void handleConnect() {
  clientConnected = true;
  server.send(200, "application/json", "{\"ok\":true}");
}

void handleDisconnect() {
  clientConnected = false;
  server.send(200, "application/json", "{\"ok\":true}");
}

// ── LED Update ───────────────────────────────────────────────────────────────
void updateLED() {
  uint8_t stations = WiFi.softAPgetStationNum();
  bool connected = (stations > 0);

  if (connected) {
    if (!clientConnected) {
      clientConnected = true;
      // GRUEN = verbunden
      // S3-Zero WS2812: Color(R, G, B) - Farbreihenfolge RGB
      led.setPixelColor(0, led.Color(60, 0, 0));  // Gruen
      led.show();
    }
  } else {
    if (clientConnected) {
      clientConnected = false;
    }
    // ROT blinkend = nicht verbunden
    uint32_t now = millis();
    if (now - lastBlink > 600) {
      lastBlink = now;
      blinkState = !blinkState;
      led.setPixelColor(0, blinkState ? led.Color(0, 60, 0) : led.Color(0, 0, 0));  // Rot
      led.show();
    }
  }
}

// ── Vorlagen NVS Funktionen ───────────────────────────────────────────────────

// Liest gespeicherte Vorlagen aus NVS, gibt JSON-String zurück
// Wenn leer -> gibt leeren String zurück
String loadTemplatesFromNVS() {
  prefs.begin("rd_tmpl", true);  // read-only
  String data = prefs.getString("templates", "");
  prefs.end();
  return data;
}

// Speichert Vorlagen-JSON in NVS
void saveTemplatesToNVS(const String& json) {
  prefs.begin("rd_tmpl", false);  // read-write
  prefs.putString("templates", json);
  prefs.end();
}

