  const c=document.getElementById('mContent').value.trim();
  if(!t||!c){alert('Bitte Titel und Text eingeben');return;}
  if(editIdx>=0)templates[editIdx]={t,c};else templates.push({t,c});
  closeModal();render();saveToESP();
}

function delTmpl(i){
  const name=templates[i]?templates[i].t:'?';
  if(!confirm('Loeschen: "'+name+'"?'))return;
  templates.splice(i,1);
  render();saveToESP();
}

async function resetTemplates(){
  if(!confirm('Alle Vorlagen auf Standard zuruecksetzen?'))return;
  templates=getDefaults();render();saveToESP();
}

// ── Export (iOS: kein Download moeglich -> Text zum Kopieren) ─
function exportTemplates(){
  let txt='';
  templates.forEach(t=>{txt+='=== '+t.t+' ===\n'+t.c+'\n\n';});
  openModal('Export - Text kopieren','Alles markieren und kopieren (langer Druck -> Alles auswaehlen)','',txt,doExportCopy);
}
function doExportCopy(){
  const ta=document.getElementById('mContent');
  ta.select();ta.setSelectionRange(0,99999);
  try{document.execCommand('copy');toast('\u2713 Kopiert!');}
  catch(e){toast('Manuell kopieren',1);}
}

// ── Import (iOS: Text einfuegen statt Datei) ─────────────────
function showImportModal(){
  openModal('Import - Text einfuegen','Vorlagen-Text hier einfuegen (aus Export kopiert)','','',doImportText);
}
function doImportText(){
  const text=document.getElementById('mContent').value;
  const titleRe=/=== (.+?) ===/g;
  const titles=[];let m;
  while((m=titleRe.exec(text))!==null)titles.push(m[1]);
  const parts=text.split(/=== .+? ===\n/).slice(1).map(s=>s.trim());
  const imported=titles.map((t,i)=>({t,c:parts[i]||''})).filter(x=>x.c);
  if(!imported.length){toast('Keine Vorlagen gefunden',1);return;}
  templates=templates.concat(imported);
  closeModal();render();saveToESP();
  toast('\u2713 '+imported.length+' importiert');
}

