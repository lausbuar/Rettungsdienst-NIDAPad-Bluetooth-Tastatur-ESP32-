// ── Modifier ─────────────────────────────────────────────────────────────────
#define MOD_NONE  0x00
#define MOD_SHIFT 0x02
#define MOD_ALTGR 0x40

// ── Taste senden ─────────────────────────────────────────────────────────────
void sendKey(uint8_t keycode, uint8_t modifier) {
  KeyReport report;
  memset(&report, 0, sizeof(report));
  report.modifiers = modifier;
  report.keys[0]   = keycode;
  Keyboard.sendReport(&report);
  delay(12);
  memset(&report, 0, sizeof(report));
  Keyboard.sendReport(&report);
  delay(10);
}

// ── Zeichen senden DE-QWERTZ ──────────────────────────────────────────────────
void sendChar(char c) {
  switch(c) {
    case 'a': sendKey(0x04,MOD_NONE);  break; case 'A': sendKey(0x04,MOD_SHIFT); break;
    case 'b': sendKey(0x05,MOD_NONE);  break; case 'B': sendKey(0x05,MOD_SHIFT); break;
    case 'c': sendKey(0x06,MOD_NONE);  break; case 'C': sendKey(0x06,MOD_SHIFT); break;
    case 'd': sendKey(0x07,MOD_NONE);  break; case 'D': sendKey(0x07,MOD_SHIFT); break;
    case 'e': sendKey(0x08,MOD_NONE);  break; case 'E': sendKey(0x08,MOD_SHIFT); break;
    case 'f': sendKey(0x09,MOD_NONE);  break; case 'F': sendKey(0x09,MOD_SHIFT); break;
    case 'g': sendKey(0x0A,MOD_NONE);  break; case 'G': sendKey(0x0A,MOD_SHIFT); break;
    case 'h': sendKey(0x0B,MOD_NONE);  break; case 'H': sendKey(0x0B,MOD_SHIFT); break;
    case 'i': sendKey(0x0C,MOD_NONE);  break; case 'I': sendKey(0x0C,MOD_SHIFT); break;
    case 'j': sendKey(0x0D,MOD_NONE);  break; case 'J': sendKey(0x0D,MOD_SHIFT); break;
    case 'k': sendKey(0x0E,MOD_NONE);  break; case 'K': sendKey(0x0E,MOD_SHIFT); break;
    case 'l': sendKey(0x0F,MOD_NONE);  break; case 'L': sendKey(0x0F,MOD_SHIFT); break;
    case 'm': sendKey(0x10,MOD_NONE);  break; case 'M': sendKey(0x10,MOD_SHIFT); break;
    case 'n': sendKey(0x11,MOD_NONE);  break; case 'N': sendKey(0x11,MOD_SHIFT); break;
    case 'o': sendKey(0x12,MOD_NONE);  break; case 'O': sendKey(0x12,MOD_SHIFT); break;
    case 'p': sendKey(0x13,MOD_NONE);  break; case 'P': sendKey(0x13,MOD_SHIFT); break;
    case 'q': sendKey(0x14,MOD_NONE);  break; case 'Q': sendKey(0x14,MOD_SHIFT); break;
    case 'r': sendKey(0x15,MOD_NONE);  break; case 'R': sendKey(0x15,MOD_SHIFT); break;
    case 's': sendKey(0x16,MOD_NONE);  break; case 'S': sendKey(0x16,MOD_SHIFT); break;
    case 't': sendKey(0x17,MOD_NONE);  break; case 'T': sendKey(0x17,MOD_SHIFT); break;
    case 'u': sendKey(0x18,MOD_NONE);  break; case 'U': sendKey(0x18,MOD_SHIFT); break;
    case 'v': sendKey(0x19,MOD_NONE);  break; case 'V': sendKey(0x19,MOD_SHIFT); break;
    case 'w': sendKey(0x1A,MOD_NONE);  break; case 'W': sendKey(0x1A,MOD_SHIFT); break;
    case 'x': sendKey(0x1B,MOD_NONE);  break; case 'X': sendKey(0x1B,MOD_SHIFT); break;
    // Y und Z getauscht QWERTZ
    case 'y': sendKey(0x1D,MOD_NONE);  break; case 'Y': sendKey(0x1D,MOD_SHIFT); break;
    case 'z': sendKey(0x1C,MOD_NONE);  break; case 'Z': sendKey(0x1C,MOD_SHIFT); break;
    // Zahlen
    case '1': sendKey(0x1E,MOD_NONE);  break; case '!': sendKey(0x1E,MOD_SHIFT); break;
    case '2': sendKey(0x1F,MOD_NONE);  break; case '"': sendKey(0x1F,MOD_SHIFT); break;
    case '3': sendKey(0x20,MOD_NONE);  break;
    case '4': sendKey(0x21,MOD_NONE);  break; case '$': sendKey(0x21,MOD_SHIFT); break;
    case '5': sendKey(0x22,MOD_NONE);  break; case '%': sendKey(0x22,MOD_SHIFT); break;
    case '6': sendKey(0x23,MOD_NONE);  break; case '&': sendKey(0x23,MOD_SHIFT); break;
    case '7': sendKey(0x24,MOD_NONE);  break; case '/': sendKey(0x24,MOD_SHIFT); break;
    case '8': sendKey(0x25,MOD_NONE);  break; case '(': sendKey(0x25,MOD_SHIFT); break;
    case '9': sendKey(0x26,MOD_NONE);  break; case ')': sendKey(0x26,MOD_SHIFT); break;
    case '0': sendKey(0x27,MOD_NONE);  break; case '=': sendKey(0x27,MOD_SHIFT); break;
    // Sonderzeichen
    case '-':  sendKey(0x38,MOD_NONE);  break; case '_': sendKey(0x38,MOD_SHIFT); break;
    case '.':  sendKey(0x37,MOD_NONE);  break; case ':': sendKey(0x37,MOD_SHIFT); break;
    case ',':  sendKey(0x36,MOD_NONE);  break; case ';': sendKey(0x36,MOD_SHIFT); break;
    case '+':  sendKey(0x30,MOD_NONE);  break; case '*': sendKey(0x30,MOD_SHIFT); break;
    case '#':  sendKey(0x31,MOD_NONE);  break;
    case '<':  sendKey(0x64,MOD_NONE);  break; case '>': sendKey(0x64,MOD_SHIFT); break;
    case '?':  sendKey(0x2D,MOD_SHIFT); break;
    case '^':  sendKey(0x35,MOD_NONE);  break;
    case '@':  sendKey(0x14,MOD_ALTGR); break;
    case '{':  sendKey(0x24,MOD_ALTGR); break; case '}': sendKey(0x27,MOD_ALTGR); break;
    case '[':  sendKey(0x25,MOD_ALTGR); break; case ']': sendKey(0x26,MOD_ALTGR); break;
    case '\\': sendKey(0x2D,MOD_ALTGR); break;
    case '|':  sendKey(0x64,MOD_ALTGR); break;
    case '\n': sendKey(0x28,MOD_NONE);  break;
    case '\t': sendKey(0x2B,MOD_NONE);  break;
    case ' ':  sendKey(0x2C,MOD_NONE);  break;
    default: break;
  }
}

// ── Unicode senden (Umlaute) ──────────────────────────────────────────────────
void sendUnicode(uint16_t cp) {
  switch(cp) {
    case 0x00E4: sendKey(0x34,MOD_NONE);  break; // ä
    case 0x00C4: sendKey(0x34,MOD_SHIFT); break; // Ä
    case 0x00F6: sendKey(0x33,MOD_NONE);  break; // ö
    case 0x00D6: sendKey(0x33,MOD_SHIFT); break; // Ö
    case 0x00FC: sendKey(0x2F,MOD_NONE);  break; // ü
    case 0x00DC: sendKey(0x2F,MOD_SHIFT); break; // Ü
    case 0x00DF: sendKey(0x2D,MOD_NONE);  break; // ß
    case 0x20AC: sendKey(0x08,MOD_ALTGR); break; // €
    case 0x00A7: sendKey(0x20,MOD_SHIFT); break; // §
    case 0x00B0: sendKey(0x35,MOD_SHIFT); break; // °
    default: break;
  }
}

// ── UTF-8 Text senden ─────────────────────────────────────────────────────────
void sendText(const String& text) {
  int i = 0;
  while (i < (int)text.length()) {
    uint8_t b = (uint8_t)text[i];
    if (b < 0x80) {
      sendChar((char)b);
      i++;
    } else if ((b & 0xE0) == 0xC0 && i+1 < (int)text.length()) {
      uint16_t cp = ((b & 0x1F) << 6) | ((uint8_t)text[i+1] & 0x3F);
      sendUnicode(cp);
      i += 2;
    } else if ((b & 0xF0) == 0xE0 && i+2 < (int)text.length()) {
      uint16_t cp = ((b & 0x0F) << 12) |
                    (((uint8_t)text[i+1] & 0x3F) << 6) |
                    ((uint8_t)text[i+2] & 0x3F);
      sendUnicode(cp);
      i += 3;
    } else { i++; }
    delay(15);
  }
}

